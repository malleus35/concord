{
  "name": "@malleus35/concord",
  "version": "0.1.0",
  "description": "Sync AI harness assets (skills / subagents / hooks / MCP / instructions / plugins) across Claude Code, Codex, and OpenCode.",
  "type": "module",
  "bin": {
    "concord": "dist/src/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "poc:1": "tsx scripts/poc/poc-1-toml.ts",
    "poc:2": "tsx scripts/poc/poc-2-jsonc.ts",
    "poc:3": "tsx scripts/poc/poc-3-yaml.ts",
    "poc:9": "tsx scripts/poc/poc-9-symlink.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "cli",
    "agents",
    "sync",
    "claude-code",
    "codex",
    "opencode",
    "skills",
    "mcp",
    "subagents",
    "hooks"
  ],
  "author": "malleus35 <malleus35@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malleus35/concord.git"
  },
  "homepage": "https://github.com/malleus35/concord#readme",
  "bugs": {
    "url": "https://github.com/malleus35/concord/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "is-wsl": "^3.1.1",
    "minimatch": "^10.2.5",
    "semver": "^7.7.4",
    "symlink-dir": "^10.0.1",
    "write-file-atomic": "^7.0.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@decimalturn/toml-patch": "^1.1.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@types/write-file-atomic": "^4.0.3",
    "jsonc-morph": "^0.3.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
